 *
 *   Plain-text passwords (for reference / login testing only — never stored):
 *     john@example.com   → 123456
 *     admin@example.com  → admin123
 *     jane@example.com   → jane1234
 *     bob@example.com    → bob5678
 *     sara@example.com   → sara9999
 *     mike@example.com   → mike2222
 *     lisa@example.com   → lisa3333
 *

 */

use("queuesmart");

// ── Helper: insert one user (credentials + profile) if email not already present
function seedUser(credentials, profile) {
  const existing = db.usercredentials.findOne({ email: credentials.email });
  if (existing) {
    print(`  SKIP — ${credentials.email} already exists.`);
    return existing._id;
  }

  const credResult = db.usercredentials.insertOne(credentials);
  const credId     = credResult.insertedId;

  db.userprofiles.insertOne({
    ...profile,
    credentialId: credId,    // FK reference to UserCredentials._id
  });

  print(`  INSERTED — ${credentials.email} (${credentials.role})`);
  return credId;
}

print("\nSeeding users...\n");

