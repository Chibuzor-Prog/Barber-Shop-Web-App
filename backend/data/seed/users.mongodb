// ── Summary ───────────────────────────────────────────────────────────────────
print("\n── Users in database ─────────────────────────────────────────────────────");
db.usercredentials.find({}, { email: 1, role: 1 }).forEach(u => {
  print(`  [${u.role.toUpperCase()}] ${u.email}`);
});
print(`\nTotal credentials: ${db.usercredentials.countDocuments()}`);
print(`Total profiles:    ${db.userprofiles.countDocuments()}`);

// ── Create indexes ────────────────────────────────────────────────────────────
db.usercredentials.createIndex({ email: 1 }, { unique: true });
db.userprofiles.createIndex({ credentialId: 1 }, { unique: true });
db.userprofiles.createIndex({ email: 1 });

print("\nIndexes created on usercredentials and userprofiles.");
print("User seeding complete.");
