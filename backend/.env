# backend/.env
# Copy this file to .env and fill in your values

# MongoDB connection string
# Local:   mongodb://localhost:27017/queuesmart
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/queuesmart
MONGO_URI=mongodb://127.0.0.1:27017/queuesmart

# Server port
PORT=5001

# Node environment: development | test | production
NODE_ENV=development

# bcrypt salt rounds (10 is a good default)
BCRYPT_ROUNDS=10
