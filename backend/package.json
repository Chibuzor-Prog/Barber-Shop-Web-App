{
  "name": "queuesmart-backend",
  "version": "1.0.0",
  "description": "QueueSmart backend API with MongoDB persistence",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test jest --coverage --runInBand --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --watch --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "mongoose": "^8.3.4"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.2.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    },
    "testTimeout": 30000
  },
  "config": {
  "mongodbMemoryServer": {
    "version": "6.0.12"
  }
}
}
