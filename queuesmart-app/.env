# queuesmart-app/.env
# Copy this file to .env and adjust the URL to match your running backend.
#
# MongoDB backend runs on port 5001:
# VITE_API_URL=http://127.0.0.1:5001
#
# PostgreSQL backend runs on port 5002:
# VITE_API_URL=http://127.0.0.1:5002
#
# If this variable is not set, src/api/config.ts falls back to port 5001 (MongoDB).

VITE_API_URL=http://127.0.0.1:5001


# ── Variant C: Google Gemini (SmartAssistant-Gemini.tsx) ─────────────────────
# Get free key: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=A...